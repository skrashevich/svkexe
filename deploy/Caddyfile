{
	email {$ACME_EMAIL}
	admin off
}

*.{$DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}

	# S1: Strip ALL spoofed incoming auth headers before anything else
	request_header -X-ExeDev-Userid
	request_header -X-ExeDev-Email

	# Forward auth to Authelia
	forward_auth authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Email Remote-Groups
	}

	# Inject verified identity from Authelia response
	header_up X-ExeDev-Userid {http.reverse_proxy.header.Remote-User}
	header_up X-ExeDev-Email {http.reverse_proxy.header.Remote-Email}

	reverse_proxy gateway:8080 {
		# SSE support: disable buffering for streaming responses
		flush_interval -1
		# WebSocket: Caddy passes Upgrade header automatically
	}
}
