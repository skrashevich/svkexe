{
	email {$ACME_EMAIL}
	admin off
}

# Gateway root and container subdomains both terminate at the Go gateway —
# authentication lives there (web login form + session cookies).
(gateway_backend) {
	# Always strip spoofable identity headers before they reach the gateway;
	# the gateway sets them from its own session store for downstream services
	# (Shelley rate limiter, proxy).
	request_header -X-ExeDev-Userid
	request_header -X-ExeDev-Email

	reverse_proxy gateway:8080 {
		# SSE: disable buffering; WebSocket upgrades pass through automatically.
		flush_interval -1
	}
}

{$DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
	import gateway_backend
}

*.{$DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
	import gateway_backend
}
